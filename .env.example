SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# PIN to unlock in-app diagnostic logs (7 hidden taps on logo / More subtitle)
DIAGNOSTIC_LOGS_PIN=choose-a-pin-only-you-know

# Optional: database password for `supabase link` / `supabase db push` only (never commit real value)
# SUPABASE_DB_PASSWORD=your-database-password

# Optional: SMTP for reliable auth emails (admin OTP, confirmations, resets).
# Only needed when running `supabase config push` with [auth.email.smtp] enabled.
# Never commit real values.
# SMTP_HOST=smtp.resend.com
# SMTP_USER=resend
# SMTP_PASS=your-smtp-api-key
# SMTP_ADMIN_EMAIL=admin@yourdomain.com
# SMTP_SENDER_NAME=MyPlanr
