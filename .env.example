# App runtime config ONLY (bundled into the app). Nothing secret here.
# Copy to .env and fill in. The anon/publishable key is public by design.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional PIN to unlock in-app diagnostic logs (7 hidden taps on More subtitle).
# Leave blank/omitted to keep diagnostic logs locked.
# DIAGNOSTIC_LOGS_PIN=choose-a-pin-only-you-know

# NOTE: Server-only secrets (DB password, SMTP, pooler) do NOT go here — they
# would ship inside the app. Put them in .env.server (see .env.server.example).
