# SERVER-ONLY secrets. NEVER bundled into the app. Copy to .env.server.
# Loaded by scripts/supabase_push.sh and needed for `supabase config push`.
# Load manually with:  set -a; source .env.server; set +a

# Direct DB password (for `supabase db push` / migrations).
SUPABASE_DB_PASSWORD=your-database-password

# Optional: pooler connection string for ad-hoc SQL / seed runs.
# SUPABASE_POOLER_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# SMTP for reliable auth emails (admin OTP, confirmations, resets).
# Only needed when running `supabase config push` with [auth.email.smtp] enabled.
SMTP_HOST=smtp.gmail.com
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-app-password
SMTP_ADMIN_EMAIL=admin@yourdomain.com
SMTP_SENDER_NAME=MyPlanr
